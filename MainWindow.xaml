<Window x:Class="MovieTrackerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Style="{StaticResource MaterialDesignWindow}"
        Title="MainWindow" Height="800" Width="360">


    <Grid>
        <Label Content="Welcome to Movie Tracker" HorizontalAlignment="Center" Margin="0,140,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="26"/>
        <Button Content="Want to Watch" HorizontalAlignment="Center" Margin="0,245,0,0" VerticalAlignment="Top" Height="60" Width="275" FontWeight="Bold" FontSize="15"/>
        <Button Content="Watching" HorizontalAlignment="Center" Margin="0,345,0,0" VerticalAlignment="Top" Height="60" Width="275" FontWeight="Bold" FontSize="15"/>
        <Button Content="Watched" HorizontalAlignment="Center" Margin="0,445,0,0" VerticalAlignment="Top" Height="60" Width="275" FontWeight="Bold" FontSize="15"/>
    </Grid>
</Window>
