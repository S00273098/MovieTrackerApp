<Window x:Class="MovieTrackerApp.StartWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Style="{StaticResource MaterialDesignWindow}"
      Title="StartWindow" Height="800" Width="360">


    <Grid Background="DimGray">
        <Label Content="Welcome to Movie Tracker" HorizontalAlignment="Center" Margin="0,200,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="26"/>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="200">
            
            <Button Content="Want to Watch" HorizontalAlignment="Center" Margin="5" VerticalAlignment="Top" 
                    Height="60" 
                    Width="275" 
                    FontWeight="Bold" 
                    FontSize="15"
                    Click="WantToWatch_Click"/>
            
            <Button Content="Watching" HorizontalAlignment="Center" Margin="5" VerticalAlignment="Top" 
                    Height="60" 
                    Width="275" 
                    FontWeight="Bold" 
                    FontSize="15"
                    Click="Watching_Click"/>
            
            <Button Content="Watched" HorizontalAlignment="Center" Margin="5" VerticalAlignment="Top" 
                    Height="60" 
                    Width="275" 
                    FontWeight="Bold" 
                    FontSize="15"
                    Click="Watched_Click"/>
        </StackPanel>
    </Grid>

</Window>
